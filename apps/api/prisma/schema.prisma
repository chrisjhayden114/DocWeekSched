generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ATTENDEE
  SPEAKER
}

enum QuestionType {
  SINGLE
  MULTI
  TEXT
}

enum SessionAttendanceStatus {
  JOINING
  NOT_JOINING
}

enum SessionJoinMode {
  VIRTUAL
  IN_PERSON
  ASYNC
}

enum ParticipantType {
  GRAD_STUDENT
  EDD_STUDENT
  PHD_STUDENT
  EDL_ALUMNI
  PROFESSOR
}

enum SessionResourceKind {
  LINK
  FILE
}

enum NetworkChannel {
  GENERAL
  MEETUP
  MOMENTS
  LOCAL
  ICEBREAKER
}

enum NotificationKind {
  COMMUNITY_THREAD
  COMMUNITY_REPLY
  MESSAGE
  ADMIN_REQUEST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  photoUrl     String?
  researchInterests String?
  participantType ParticipantType?
  passwordHash String
  engagementPoints Int @default(0)
  profileSetupToken String?   @unique
  profileSetupTokenExpiresAt DateTime?
  createdAt    DateTime @default(now())
  sessionBookmarks SessionBookmark[]
  sessionAttendances SessionAttendance[]
  sessionLikes SessionLike[]
  eventsCreated Event[] @relation("EventCreator")
  sessionsAsSpeaker Session[] @relation("SessionSpeaker")
  conversationMembers ConversationMember[]
  conversationMessages ConversationMessage[]
  checkIns     CheckIn[]
  surveyAnswers SurveyAnswer[]
  networkThreads NetworkThread[]
  networkReplies NetworkReply[]
  sessionDiscussionThreads SessionDiscussionThread[]
  sessionDiscussionReplies SessionDiscussionReply[]
  sessionResources SessionResource[]
  notifications UserNotification[]
}

model Event {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  bannerUrl String?
  logoUrl   String?
  timezone  String
  startDate DateTime
  endDate   DateTime
  sessions  Session[]
  announcements Announcement[]
  surveys   Survey[]
  conversations Conversation[]
  checkIns  CheckIn[]
  networkThreads NetworkThread[]
  createdBy   User?   @relation("EventCreator", fields: [createdById], references: [id])
  createdById String?
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  speakers    String?
  imageUrl    String?
  zoomLink    String?
  recordingUrl String?
  fileUrl     String?
  fileLink    String?
  allowVirtualJoin Boolean @default(true)
  startsAt    DateTime
  endsAt      DateTime
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String
  speaker     User?    @relation("SessionSpeaker", fields: [speakerId], references: [id])
  speakerId   String?
  bookmarks   SessionBookmark[]
  attendances SessionAttendance[]
  likes       SessionLike[]
  conversations Conversation[]
  discussionThreads SessionDiscussionThread[]
  resources SessionResource[]
}

model SessionBookmark {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId String
  createdAt DateTime @default(now())

  @@unique([userId, sessionId])
}

model SessionAttendance {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId String
  status    SessionAttendanceStatus
  joinMode  SessionJoinMode?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sessionId])
}

model SessionLike {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId String
  createdAt DateTime @default(now())

  @@unique([userId, sessionId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
}

model Survey {
  id        String   @id @default(cuid())
  title     String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  questions SurveyQuestion[]
}

model SurveyQuestion {
  id        String   @id @default(cuid())
  prompt    String
  type      QuestionType
  options   String[]
  survey    Survey   @relation(fields: [surveyId], references: [id])
  surveyId  String
  answers   SurveyAnswer[]
}

model SurveyAnswer {
  id         String   @id @default(cuid())
  question   SurveyQuestion @relation(fields: [questionId], references: [id])
  questionId String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  answer     String
  createdAt  DateTime @default(now())
}

enum ConversationType {
  EVENT
  DIRECT
  GROUP
  SESSION
}

model Conversation {
  id        String   @id @default(cuid())
  name      String?
  type      ConversationType
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  session   Session? @relation(fields: [sessionId], references: [id])
  sessionId String?  @unique
  members   ConversationMember[]
  messages  ConversationMessage[]
}

model ConversationMember {
  id             String @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  user           User @relation(fields: [userId], references: [id])
  userId         String

  @@unique([conversationId, userId])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  body           String
  createdAt      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  user           User     @relation(fields: [userId], references: [id])
  userId         String
}

model CheckIn {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model NetworkThread {
  id        String   @id @default(cuid())
  title     String
  body      String
  channel   NetworkChannel @default(GENERAL)
  meetupMode SessionJoinMode?
  meetupStartsAt DateTime?
  meetupMeetingUrl String?
  meetupInviteEveryone Boolean @default(false)
  meetupParticipantIds String[] @default([])
  taggedUserIds String[] @default([])
  imageUrl  String?
  imageUrls String[] @default([])
  mapsUrl   String?
  createdAt DateTime @default(now())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   NetworkReply[]
}

model UserNotification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId        String?
  kind           NotificationKind
  title          String
  body           String?
  threadId       String?
  conversationId String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model NetworkReply {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  threadId  String
  thread    NetworkThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model SessionDiscussionThread {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   SessionDiscussionReply[]
}

model SessionDiscussionReply {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  threadId  String
  thread    SessionDiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model SessionResource {
  id        String   @id @default(cuid())
  title     String
  kind      SessionResourceKind
  url       String
  createdAt DateTime @default(now())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
