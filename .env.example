DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
# REQUIRED — API refuses to boot if unset or weak (<16 chars / "dev-secret")
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_INVITE_CODE="set-a-strong-admin-code"
API_PORT=4000
# Many hosts inject PORT; API uses PORT or API_PORT.
WEB_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Session cookies (Phase 1)
# Preferred production (same-site): point API at api.ukedl.com, then:
#   COOKIE_DOMAIN=.ukedl.com
#   COOKIE_SAMESITE=lax
#   COOKIE_SECURE=true
# Localhost: leave COOKIE_DOMAIN empty; SameSite=lax works on localhost without Domain.
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# Interim cross-site (API still on *.onrender.com): COOKIE_SAMESITE=none + COOKIE_SECURE=true
# SESSION_COOKIE_NAME=ep_session
# CSRF_COOKIE_NAME=ep_csrf
# INVITE_TOKEN_DAYS=7

# Netlify (apps/web): set NEXT_PUBLIC_API_URL to https://api.ukedl.com (preferred) or current Render URL.
# API: set WEB_BASE_URL to https://ukedl.com for CORS allowlist (credentials required).

# Optional: Resend for invites / password reset / email verification.
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Conference <onboarding@yourdomain.com>"

# Stripe (SaaS billing) — Phase 3.
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_ORG_ANNUAL_PRICE_ID="price_..."
