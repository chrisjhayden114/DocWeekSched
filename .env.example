DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
JWT_SECRET="change-me"
ADMIN_INVITE_CODE="set-a-strong-admin-code"
API_PORT=4000
# Many hosts inject PORT; API uses PORT or API_PORT.
WEB_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
EXPO_PUBLIC_API_URL="http://localhost:4000"

# Netlify (apps/web only): set NEXT_PUBLIC_API_URL to your deployed API base URL (https://...).
# API server: set WEB_BASE_URL to your Netlify site origin (https://your-site.netlify.app) for CORS.

# Optional: Resend (https://resend.com) for admin participant invites. Without RESEND_API_KEY, invite URLs are only logged server-side.
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Conference <onboarding@yourdomain.com>"
