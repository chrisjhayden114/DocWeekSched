# =============================================================================
# Colloquium environment reference
#
# REQUIRED IN PRODUCTION vars are listed with what breaks without them in
# RUNBOOK.md §10. The API refuses to boot in production if WEB_BASE_URL or
# API_PUBLIC_URL still point at localhost (env preflight, lib/env.ts), and
# logs one warning line per degraded subsystem at boot.
# =============================================================================

# --- Core (API refuses to boot without these) -------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
# Min 16 chars; "dev-secret" is rejected.
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_INVITE_CODE="set-a-strong-admin-code"

# --- Ports & public origins --------------------------------------------------
# Many hosts inject PORT; the API uses PORT or API_PORT (default 4000).
API_PORT=4000
# Public web origin: CORS allowlist, emailed links, billing redirects.
# Production: https://ukedl.com — localhost here is a FATAL boot error in prod.
WEB_BASE_URL="http://localhost:3000"
# Public API origin: ICS feed URLs. Production: https://api.ukedl.com —
# unset/localhost is a FATAL boot error in prod.
# API_PUBLIC_URL="http://localhost:4000"
# Web build-time: where the browser reaches the API.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Session cookies ---------------------------------------------------------
# Preferred production (same-site): API at api.ukedl.com, then:
#   COOKIE_DOMAIN=.ukedl.com  COOKIE_SAMESITE=lax  COOKIE_SECURE=true
# Interim cross-site (API still on *.onrender.com): COOKIE_SAMESITE=none +
# COOKIE_SECURE=true. Localhost: leave COOKIE_DOMAIN empty.
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# SESSION_COOKIE_NAME=ep_session
# CSRF_COOKIE_NAME=ep_csrf
# Account-setup invite token lifetime (days).
# INVITE_TOKEN_DAYS=7

# --- Email (Resend) ----------------------------------------------------------
# Unset → invites/password-reset/verification fall back to copy-link in the UI.
# EMAIL_PROVIDER=none is the kill switch even with a key present.
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Conference <onboarding@yourdomain.com>"
# EMAIL_PROVIDER=resend

# --- Web push (VAPID) --------------------------------------------------------
# Generate once with `npx web-push generate-vapid-keys`. Unset → web push is
# disabled (subscribe endpoints refuse). Rotating keys invalidates every
# existing browser subscription.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT="mailto:support@yourdomain.com"

# --- Object storage (S3 / R2 / MinIO) ----------------------------------------
# Unset → uploads are stored as data-URLs in Postgres (works, but bloats rows).
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_BASE_URL=https://files.example.com
# STORAGE_MAX_UPLOAD_BYTES=20000000

# --- Billing (Lemon Squeezy, merchant of record) ------------------------------
# Unset in production → checkout/portal return 503 ("billing unconfigured").
# Sandbox first: Test Mode store, products/variants, webhook.
# BILLING_PROVIDER=lemonsqueezy
# BILLING_PROVIDER=mock   # local/tests without LS keys (never in production)
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_CUSTOMER_PORTAL_URL=
# LEMONSQUEEZY_VARIANT_PER_EVENT_250=
# LEMONSQUEEZY_VARIANT_PER_EVENT_500=
# LEMONSQUEEZY_VARIANT_PER_EVENT_1000=
# LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
# LEMONSQUEEZY_VARIANT_PRO_ANNUAL=
# Webhook URL: https://<api-host>/billing/webhooks/lemonsqueezy
# Events: order_created, subscription_created, subscription_updated,
#   subscription_cancelled, subscription_payment_failed, subscription_payment_success
# HMAC secret for the MOCK provider's webhook only (tests/local).
# BILLING_WEBHOOK_SECRET=test-webhook-secret

# --- AI provider --------------------------------------------------------------
# AI_PROVIDER=mock (default) is the kill switch: all agents (agenda ingest,
# concierge, matchmaker, ops inbox, recap) return deterministic mock output
# with no external calls.
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-20250514
# AI_EMBED_MODEL=
# Per-event hard caps on metered AI actions:
# AI_HARD_CAP_INGEST_PER_EVENT=100
# AI_HARD_CAP_CONCIERGE_PER_EVENT=10000
# AI_HARD_CAP_OTHER_PER_EVENT=10000
# Process agenda-ingest jobs inline instead of via the poller (dev only).
# AGENDA_INGEST_INLINE=1

# --- Web security headers (build-time, apps/web) -------------------------------
# CSP ships as Content-Security-Policy-Report-Only by default. After verifying
# report-only in production (LAUNCH_CHECKLIST), set CSP_ENFORCE=1 in the web
# build env to switch to enforcing. Never add 'unsafe-inline' to script-src.
# When NEXT_PUBLIC_SENTRY_DSN is set, its exact ingest origin is appended to
# connect-src automatically so enforcing doesn't break web error reporting.
# CSP_ENFORCE=1

# --- Error tracking (Sentry) ---------------------------------------------------
# Entirely optional — SDKs stay inert when DSN unset.
# SENTRY_DSN=                    # API (@sentry/node)
# SENTRY_RELEASE=                # git SHA (Render sets RENDER_GIT_COMMIT as fallback)
# NEXT_PUBLIC_SENTRY_DSN=        # Web browser (@sentry/nextjs)
# NEXT_PUBLIC_SENTRY_RELEASE=    # git SHA for web release tagging
# SENTRY_AUTH_TOKEN=             # only for source-map upload at build time

# --- Background jobs & interval tuning ----------------------------------------
# BackgroundJob poller tick (ms).
# JOB_POLL_INTERVAL_MS=5000
# /health/ready reports not-ready when the poller heartbeat is older than this (ms).
# JOB_POLL_STALE_MS=60000
# Push-queue flush + "session starting soon" interval (ms).
# NOTIFICATION_JOB_INTERVAL_MS=60000
# Ops Inbox detector sweep enqueue interval (ms).
# OPS_DETECT_SWEEP_INTERVAL_MS=300000

# --- Product tuning -------------------------------------------------------------
# Max interrupt-class pushes per user per day (rest queue to the digest).
# NOTIFICATION_DAILY_PUSH_BUDGET=5
# Hours a waitlist seat offer is held before expiring.
# WAITLIST_SEAT_HOLD_HOURS=24
# Announcement email sends allowed per event per hour.
# ANNOUNCEMENT_EMAIL_RATE_PER_HOUR=3

# --- Safety switches -------------------------------------------------------------
# Destructive-DB guard override (RUNBOOK.md §6). Set ONLY when the target
# database is disposable (local Postgres, restore-drill branch). Required to
# run the DB test suite against a hosted dev database.
# ALLOW_DESTRUCTIVE_DB=1
