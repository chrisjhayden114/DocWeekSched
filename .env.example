DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
# REQUIRED — API refuses to boot if unset or weak (<16 chars / "dev-secret")
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_INVITE_CODE="set-a-strong-admin-code"
API_PORT=4000
# Many hosts inject PORT; API uses PORT or API_PORT.
WEB_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Session cookies (Phase 1)
# Preferred production (same-site): point API at api.ukedl.com, then:
#   COOKIE_DOMAIN=.ukedl.com
#   COOKIE_SAMESITE=lax
#   COOKIE_SECURE=true
# Localhost: leave COOKIE_DOMAIN empty; SameSite=lax works on localhost without Domain.
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# Interim cross-site (API still on *.onrender.com): COOKIE_SAMESITE=none + COOKIE_SECURE=true
# SESSION_COOKIE_NAME=ep_session
# CSRF_COOKIE_NAME=ep_csrf
# INVITE_TOKEN_DAYS=7

# Netlify (apps/web): set NEXT_PUBLIC_API_URL to https://api.ukedl.com (preferred) or current Render URL.
# API: set WEB_BASE_URL to https://ukedl.com for CORS allowlist (credentials required).

# Optional: Resend for invites / password reset / email verification.
# If unset, API returns copy-link fallback (no key names in the UI).
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Conference <onboarding@yourdomain.com>"
# EMAIL_PROVIDER=resend

# Object storage (S3 / R2 / MinIO). If unset, session files stay as data-URL fallback.
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_BASE_URL=https://files.example.com
# STORAGE_MAX_UPLOAD_BYTES=20000000

# Billing — Lemon Squeezy merchant of record (Phase 3)
# Sandbox first: create a Test Mode store, products/variants, and webhook.
# BILLING_PROVIDER=lemonsqueezy
# BILLING_PROVIDER=mock   # local/tests without LS keys
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_CUSTOMER_PORTAL_URL=
# LEMONSQUEEZY_VARIANT_PER_EVENT_250=
# LEMONSQUEEZY_VARIANT_PER_EVENT_500=
# LEMONSQUEEZY_VARIANT_PER_EVENT_1000=
# LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
# LEMONSQUEEZY_VARIANT_PRO_ANNUAL=
# Webhook URL: https://<api-host>/billing/webhooks/lemonsqueezy
# Events: order_created, subscription_created, subscription_updated,
#   subscription_cancelled, subscription_payment_failed, subscription_payment_success

# Legacy Stripe stubs (unused — provider interface targets MoR first)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
