{
  "name": "event-app",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9"
  },
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "test": "npm --workspace @event-app/api run test",
    "build:api": "npm --workspace @event-app/api run build",
    "build:web": "npm --workspace @event-app/web run build"
  }
}
